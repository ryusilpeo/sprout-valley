{
  "$comment": "Phaser 3 asset index for the Sprout Lands Basic pack (by Cup Nooble). All art is 16x16-based pixel art. Load with pixelArt:true / roundPixels:true in your game config. Paths are relative to `basePath` (assumes the web root serves the `public/` folder). Duplicate spaced/underscored filenames were verified byte-identical and collapsed to the underscore version; identical twins are listed under `aliases`.",
  "meta": {
    "pack": "Sprout Lands - Basic Pack",
    "author": "Cup Nooble",
    "credit": "Assets -From: Sprout Lands -By: Cup Nooble",
    "license": "Non-commercial. No NFT/AI-training use. Do not redistribute/resell the pack. Credit required.",
    "links": {
      "twitter": "https://twitter.com/Sprout_Lands",
      "carrd": "https://cupnooble.carrd.co"
    }
  },
  "config": {
    "tileSize": 16,
    "basePath": "assets/sprout",
    "recommendedGameConfig": {
      "pixelArt": true,
      "roundPixels": true,
      "antialias": false
    },
    "$note": "For crisp pixel art, set pixelArt:true (nearest-neighbor). Tilesets are also loaded as spritesheets so individual 16x16 tiles are addressable by frame index; for Tiled-based maps, use tileWidth/tileHeight = 16."
  },
  "loaderTypes": {
    "image": "this.load.image(key, path)",
    "spritesheet": "this.load.spritesheet(key, path, { frameWidth, frameHeight })",
    "tileset": "this.load.image(key, path); then map.addTilesetImage(nameInTiled, key) OR use as spritesheet for manual tile placement"
  },
