  "characters": {
    "player": {
      "file": "Characters/Basic Charakter Spritesheet.png",
      "load": "spritesheet",
      "frameWidth": 48,
      "frameHeight": 48,
      "columns": 4,
      "rows": 4,
      "frameCount": 16,
      "description": "Main player character. 4x4 grid; each row is a facing direction, each column a 4-frame walk/idle cycle. Character is drawn small and centered in the 48x48 cell (leaves room for tool-use frames to line up with the actions sheet).",
      "animations": {
        "walk_down":  { "frames": [0, 1, 2, 3],    "frameRate": 8, "repeat": -1 },
        "walk_up":    { "frames": [4, 5, 6, 7],    "frameRate": 8, "repeat": -1 },
        "walk_right": { "frames": [8, 9, 10, 11],  "frameRate": 8, "repeat": -1 },
        "walk_left":  { "frames": [12, 13, 14, 15], "frameRate": 8, "repeat": -1 },
        "idle_down":  { "frames": [0], "frameRate": 1, "repeat": 0 }
      },
      "$note": "Row->direction mapping verified visually (row0 faces the camera/down, row1 faces away/up, rows2-3 are side profiles). 'left' can alternatively be produced by flipX on the right frames if you prefer."
    },
    "player_actions": {
      "file": "Characters/Basic Charakter Actions.png",
      "load": "spritesheet",
      "frameWidth": 48,
      "frameHeight": 48,
      "columns": 2,
      "rows": 12,
      "frameCount": 24,
      "description": "Tool-use / action poses for the player. Same 48x48 cell as the player sheet so frames register in place. 12 rows, each a 2-frame action animation (watering, hoeing, axing, digging, etc.).",
      "animations": {
        "action_0":  { "frames": [0, 1],   "frameRate": 8, "repeat": 0 },
        "action_1":  { "frames": [2, 3],   "frameRate": 8, "repeat": 0 },
        "action_2":  { "frames": [4, 5],   "frameRate": 8, "repeat": 0 },
        "action_3":  { "frames": [6, 7],   "frameRate": 8, "repeat": 0 },
        "action_4":  { "frames": [8, 9],   "frameRate": 8, "repeat": 0 },
        "action_5":  { "frames": [10, 11], "frameRate": 8, "repeat": 0 },
        "action_6":  { "frames": [12, 13], "frameRate": 8, "repeat": 0 },
        "action_7":  { "frames": [14, 15], "frameRate": 8, "repeat": 0 },
        "action_8":  { "frames": [16, 17], "frameRate": 8, "repeat": 0 },
        "action_9":  { "frames": [18, 19], "frameRate": 8, "repeat": 0 },
        "action_10": { "frames": [20, 21], "frameRate": 8, "repeat": 0 },
        "action_11": { "frames": [22, 23], "frameRate": 8, "repeat": 0 }
      },
      "$note": "Row = 2*rowIndex, 2*rowIndex+1. Which row is which tool is not labeled in the source; assign meaningful anim keys (e.g. 'water','hoe','axe') once you match rows to your gameplay."
    },
